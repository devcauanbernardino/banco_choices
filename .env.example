# ---------------------------------------------------------------------------
# MySQL — no código atual as credenciais estão em config/conexao.php (padrão
# XAMPP: root sem senha). Para produção, o ideal é ler DB_* no Conexao e
# preencher aqui (não há leitura automática de DB_* neste repositório ainda).
# DB_HOST=localhost
# DB_NAME=bancodechoices
# DB_USER=root
# DB_PASS=
# ---------------------------------------------------------------------------

# URL pública do site (sem barra final) — usada em back_urls e webhook.
# Em desenvolvimento local, use a URL completa até a pasta pública, ex.:
# SITE_URL=http://localhost/banco_choices/public
SITE_URL=https://bancodechoices.com

# Mercado Pago (obrigatório: access token; public key para checkout)
# Use credenciais de teste ou produção do painel — nunca commite tokens reais.
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=

# Moeda da preferência (ARS = Argentina, BRL = Brasil, conforme a conta MP)
MP_CURRENCY_ID=ARS

# Segredo de validação do webhook (Painel MP → Webhooks → assinatura secreta)
MP_WEBHOOK_SECRET=

# Compatibilidade com nomes antigos (opcional)
# MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_PUBLIC_KEY=

# E-mail (PHPMailer) — credenciais após compra aprovada
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=contato@bancodechoices.com
MAIL_FROM_NAME=Banco de Choices
